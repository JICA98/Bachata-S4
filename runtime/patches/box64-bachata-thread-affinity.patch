index 2737c9bd..91b816a1 100644
--- a/src/libtools/threads.c
+++ b/src/libtools/threads.c
@@ -25,6 +25,7 @@
 #include "bridge.h"
 #include "myalign.h"
 #include "x64tls.h"
+#include "bachata_thread_affinity.h"
 #ifdef DYNAREC
 #include "dynablock.h"
 #include "dynarec/native_lock.h"
@@ -927,6 +928,33 @@ EXPORT int my_pthread_setaffinity_np_old(x64emu_t* emu, pthread_t thread, void*
 {
 	return my_pthread_setaffinity_np(emu, thread, 128, cpuset);
 }
+
+EXPORT int my_pthread_setname_np(x64emu_t* emu, pthread_t thread, const char* name)
+{
+    (void)emu;
+    int ret = pthread_setname_np(thread, name);
+    if (ret || !box64_bachata_should_pin_thread(getenv("BOX64_BACHATA_PRIME_THREAD"), name))
+        return ret;
+
+    cpu_set_t allowed;
+    if (pthread_getaffinity_np(thread, sizeof(allowed), &allowed) != 0) {
+        printf_log(LOG_INFO, "Bachata affinity: failed to query allowed CPUs for %s\n", name);
+        return ret;
+    }
+    int cpu = box64_bachata_highest_allowed_cpu(&allowed);
+    if (cpu < 0)
+        return ret;
+
+    cpu_set_t target;
+    CPU_ZERO(&target);
+    CPU_SET(cpu, &target);
+    int affinity_ret = pthread_setaffinity_np(thread, sizeof(target), &target);
+    if (affinity_ret == 0)
+        printf_log(LOG_INFO, "Bachata affinity: pinned %s to CPU %d\n", name, cpu);
+    else
+        printf_log(LOG_INFO, "Bachata affinity: failed to pin %s to CPU %d (error=%d)\n", name, cpu, affinity_ret);
+    return ret;
+}
 #endif
 
