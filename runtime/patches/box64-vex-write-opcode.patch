diff --git a/src/libtools/decopcode.c b/src/libtools/decopcode.c
index c63e15e5..90083c9f 100644
--- a/src/libtools/decopcode.c
+++ b/src/libtools/decopcode.c
@@ -14,6 +14,42 @@
 
 int decode_avx(uint8_t* addr, int idx, vex_t vex)
 {
+    if(vex.m != VEX_M_0F)
+        return 0;
+
+    uint8_t nextop;
+    switch(addr[idx++]) {
+        case 0x10:
+        case 0x12:
+        case 0x14 ... 0x16:
+        case 0x28:
+        case 0x2A:
+        case 0x2C ... 0x2F:
+        case 0x50 ... 0x6F:
+        case 0x70:
+        case 0x74 ... 0x76:
+        case 0xC2:
+        case 0xC4 ... 0xC6:
+        case 0xD1 ... 0xD5:
+        case 0xD7 ... 0xE5:
+        case 0xE8 ... 0xEF:
+        case 0xF1 ... 0xFE:
+            nextop = addr[idx++];
+            return (MODREG)?0:OPCODE_READ;
+        case 0x11:
+        case 0x13:
+        case 0x17:
+        case 0x29:
+        case 0x2B:
+        case 0x7E:
+        case 0x7F:
+        case 0x90 ... 0x9F:
+        case 0xAE:
+        case 0xC3:
+        case 0xE7:
+            nextop = addr[idx++];
+            return (MODREG)?0:OPCODE_WRITE;
+    }
     return 0;
 }
 
@@ -154,7 +190,7 @@ int decode_opcode(uintptr_t rip, int is32bits)
         switch(addr[idx++]) {
             case 0xC4:
                 vex.rex = rex;
-                tmp8u = nextop;
+                tmp8u = addr[idx++];
                 vex.m = tmp8u&0b00011111;
                 vex.rex.b = (tmp8u&0b00100000)?0:1;
                 vex.rex.x = (tmp8u&0b01000000)?0:1;
@@ -167,7 +203,7 @@ int decode_opcode(uintptr_t rip, int is32bits)
                 break;
             case 0xC5:
                 vex.rex = rex;
-                tmp8u = nextop;
+                tmp8u = addr[idx++];
                 vex.p = tmp8u&0b00000011;
                 vex.l = (tmp8u>>2)&1;
                 vex.v = ((~tmp8u)>>3)&0b1111;
