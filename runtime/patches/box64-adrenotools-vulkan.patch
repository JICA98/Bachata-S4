diff --git a/src/wrapped/wrappedvulkan.c b/src/wrapped/wrappedvulkan.c
index 8d642397..9d7c2940 100644
--- a/src/wrapped/wrappedvulkan.c
+++ b/src/wrapped/wrappedvulkan.c
@@ -18,9 +18,20 @@
 #include "myalign.h"
 #include "build_info.h"
 
-//extern char* libvulkan;
+static void* OpenBachataVulkan(void) {
+    if (!getenv("BACHATA_VULKAN_DRIVER_DIR")) {
+        return dlopen("libvulkan.so.1", RTLD_LAZY | RTLD_GLOBAL);
+    }
+    void* bridge = dlopen("libbachata_custom_vulkan.so", RTLD_NOW | RTLD_GLOBAL);
+    if (!bridge) {
+        return NULL;
+    }
+    void* (*open_custom_vulkan)(void) = dlsym(bridge, "bachata_open_custom_vulkan");
+    return open_custom_vulkan ? open_custom_vulkan() : NULL;
+}
 
 const char* vulkanName = "libvulkan.so.1";
 #define LIBNAME vulkan
+#define CUSTOM_LIBRARY_HANDLE OpenBachataVulkan
 
 typedef void(*vFpUp_t)      (void*, uint64_t, void*);
