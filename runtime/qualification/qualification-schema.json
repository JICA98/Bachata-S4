{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Bachata S4 device qualification",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "fingerprintSha256", "soc", "gpu", "api", "driverUuid", "revisions", "sessions"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "fingerprintSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
    "soc": { "type": "string", "minLength": 1 },
    "gpu": { "type": "string", "minLength": 1 },
    "api": { "type": "integer", "minimum": 31 },
    "driverUuid": { "type": "string", "minLength": 1 },
    "revisions": { "type": "object", "additionalProperties": { "type": "string", "pattern": "^[0-9a-f]{40}$" } },
    "sessions": {
      "type": "array", "minItems": 10,
      "items": {
        "type": "object", "additionalProperties": false,
        "required": ["kind", "startupMs", "frameTimeMs", "peakRssBytes", "thermal", "audioUnderruns", "droppedInput", "exitCode", "crashFreeSeconds"],
        "properties": {
          "kind": { "enum": ["cold", "warm"] },
          "startupMs": { "type": "number", "minimum": 0 },
          "frameTimeMs": {
            "type": "object", "additionalProperties": false,
            "required": ["p50", "p95", "p99"],
            "properties": { "p50": { "type": "number", "minimum": 0 }, "p95": { "type": "number", "minimum": 0 }, "p99": { "type": "number", "minimum": 0 } }
          },
          "peakRssBytes": { "type": "integer", "minimum": 0 },
          "thermal": { "type": "array", "items": { "type": "number" } },
          "audioUnderruns": { "type": "integer", "minimum": 0 },
          "droppedInput": { "type": "integer", "minimum": 0 },
          "exitCode": { "type": "integer" },
          "crashFreeSeconds": { "type": "number", "minimum": 0 }
        }
      }
    }
  }
}
