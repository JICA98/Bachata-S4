{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "FEXCore Phase 0 SM8650 evidence",
  "type": "object",
  "additionalProperties": false,
  "required": ["schemaVersion", "device", "source", "artifact", "run", "logs"],
  "properties": {
    "schemaVersion": { "const": 1 },
    "device": {
      "type": "object", "additionalProperties": false,
      "required": ["soc", "abi", "sdk", "pageSize"],
      "properties": {
        "soc": { "const": "SM8650" },
        "abi": { "const": "arm64-v8a" },
        "sdk": { "const": 36 },
        "pageSize": { "const": 4096 }
      }
    },
    "source": {
      "type": "object", "additionalProperties": false,
      "required": ["projectRevision", "fexRevision"],
      "properties": {
        "projectRevision": { "type": "string", "pattern": "^[0-9a-f]{40}$" },
        "fexRevision": { "const": "f2b679f6028ce1c38875233aecfcf5d3f8ebecec" }
      }
    },
    "artifact": {
      "type": "object", "additionalProperties": false,
      "required": ["apkSha256", "runnerSha256", "elfClass", "machine", "interpreter", "needed"],
      "properties": {
        "apkSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "runnerSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "elfClass": { "const": "ELF64" },
        "machine": { "const": "AArch64" },
        "interpreter": { "const": "/lib/ld-linux-aarch64.so.1" },
        "needed": {
          "type": "array",
          "const": ["libc.so.6", "libgcc_s.so.1", "libm.so.6", "libstdc++.so.6"]
        }
      }
    },
    "run": {
      "type": "object", "additionalProperties": false,
      "required": ["exitCode", "durationMs", "marker", "checks"],
      "properties": {
        "exitCode": { "const": 0 },
        "durationMs": { "type": "integer", "minimum": 1, "maximum": 30000 },
        "marker": { "type": "string" },
        "checks": {
          "type": "object", "additionalProperties": false,
          "required": ["gpr", "stack", "fp", "threads", "tls", "callback", "invalidation"],
          "properties": {
            "gpr": { "const": "ok" }, "stack": { "const": "ok" }, "fp": { "const": "ok" },
            "threads": { "const": "ok" }, "tls": { "const": "ok" }, "callback": { "const": "ok" },
            "invalidation": { "const": "ok" }
          }
        }
      }
    },
    "logs": {
      "type": "object", "additionalProperties": false,
      "required": ["instrumentationSha256", "logcatSha256"],
      "properties": {
        "instrumentationSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" },
        "logcatSha256": { "type": "string", "pattern": "^[0-9a-f]{64}$" }
      }
    }
  }
}
