#############################################
# Order-only phony target for OSDependent

build cmake_object_order_depends_target_OSDependent: phony || .

build externals/glslang/glslang/OSDependent/Unix/CMakeFiles/OSDependent.dir/__/__/stub.cpp.o: CXX_COMPILER__OSDependent_unscanned_Debug /home/jica/repo/Bachata-S4/externals/glslang/glslang/stub.cpp || cmake_object_order_depends_target_OSDependent
  CONFIG = Debug
  DEFINES = -DENABLE_OPT=0 -DENABLE_SPIRV -DGLSLANG_OSINCLUDE_UNIX
  DEP_FILE = externals/glslang/glslang/OSDependent/Unix/CMakeFiles/OSDependent.dir/__/__/stub.cpp.o.d
  FLAGS = -g -std=c++17 -fPIC -march=x86-64-v3 -Wall -Wmaybe-uninitialized -Wuninitialized -Wunused -Wunused-local-typedefs -Wimplicit-fallthrough -Wunused-parameter -Wunused-value -Wunused-variable -Wunused-but-set-parameter -Wunused-but-set-variable -fno-exceptions -fno-rtti -Werror=deprecated-copy
  OBJECT_DIR = externals/glslang/glslang/OSDependent/Unix/CMakeFiles/OSDependent.dir
  OBJECT_FILE_DIR = externals/glslang/glslang/OSDependent/Unix/CMakeFiles/OSDependent.dir/__/__
  TARGET_SUPPORT_DIR = externals/glslang/glslang/OSDependent/Unix/CMakeFiles/OSDependent.dir


