#############################################
# Utility command for package

build externals/sdl3/CMakeFiles/package.util: CUSTOM_COMMAND externals/sdl3/all
  COMMAND = cd /home/jica/repo/Bachata-S4/build-tests && /usr/bin/cpack --config ./CPackConfig.cmake
  DESC = Run CPack packaging tool...
  pool = console
  restat = 1

build externals/sdl3/package: phony externals/sdl3/CMakeFiles/package.util


