# Object build statements for STATIC_LIBRARY target crypto


#############################################
# Order-only phony target for crypto

build cmake_object_order_depends_target_crypto: phony || cmake_object_order_depends_target_compat_obj cmake_object_order_depends_target_crypto_obj

build externals/libressl/crypto/CMakeFiles/crypto.dir/empty.c.o: C_COMPILER__crypto_unscanned_Debug /home/jica/repo/Bachata-S4/externals/libressl/crypto/empty.c || cmake_object_order_depends_target_crypto
  CONFIG = Debug
  DEFINES = -DHAVE_ARC4RANDOM_BUF -DHAVE_ARC4RANDOM_UNIFORM -DHAVE_ARPA_NAMESER_H -DHAVE_ASPRINTF -DHAVE_CLOCK_GETTIME -DHAVE_ENDIAN_H -DHAVE_ERR_H -DHAVE_EXPLICIT_BZERO -DHAVE_FTRUNCATE -DHAVE_GETAUXVAL -DHAVE_GETDELIM -DHAVE_GETENTROPY -DHAVE_GETLINE -DHAVE_GETOPT -DHAVE_GETPAGESIZE -DHAVE_GNU_STACK -DHAVE_MEMMEM -DHAVE_NETINET_IP_H -DHAVE_REALLOCARRAY -DHAVE_RESOLV_H -DHAVE_STRCASECMP -DHAVE_STRLCAT -DHAVE_STRLCPY -DHAVE_STRNDUP -DHAVE_STRNLEN -DHAVE_STRSEP -DHAVE_SYSLOG -DLIBRESSL_CRYPTO_INTERNAL -DLIBRESSL_INTERNAL -DLIBRESSL_USE_AES_ASSEMBLY -DLIBRESSL_USE_BN_ASSEMBLY -DLIBRESSL_USE_GCM_ASSEMBLY -DLIBRESSL_USE_RC4_ASSEMBLY -DLIBRESSL_USE_SHA_ASSEMBLY -DOPENSSLDIR=\"etc/ssl\" -DOPENSSL_BN_ASM_MONT -DOPENSSL_BN_ASM_MONT5 -DOPENSSL_NO_HW_PADLOCK -D_BSD_SOURCE -D_DEFAULT_SOURCE -D_GNU_SOURCE -D_POSIX_SOURCE -D__BEGIN_HIDDEN_DECLS="" -D__END_HIDDEN_DECLS=""
  DEP_FILE = externals/libressl/crypto/CMakeFiles/crypto.dir/empty.c.o.d
  FLAGS = -Wall -g -fPIC -march=x86-64-v3 -Wno-pointer-sign
  INCLUDES = -I/home/jica/repo/Bachata-S4/build-tests/include
  OBJECT_DIR = externals/libressl/crypto/CMakeFiles/crypto.dir
  OBJECT_FILE_DIR = externals/libressl/crypto/CMakeFiles/crypto.dir
  TARGET_SUPPORT_DIR = externals/libressl/crypto/CMakeFiles/crypto.dir


